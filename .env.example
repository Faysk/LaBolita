# Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente para testes/preview sem infraestrutura. Não use em produção.
NEXT_PUBLIC_LABOLITA_DEMO_MODE=

# Somente para rotas server-side administrativas. Nunca exponha no browser.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: provedor de resultados. O app funciona em modo demonstração sem ela.
FOOTBALL_DATA_API_KEY=

# Sincronização de placares observados. Proteja o endpoint /api/cron/results.
RESULTS_FEED_URL=
CRON_SECRET=
