# Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente para testes/preview sem infraestrutura. Não use em produção.
NEXT_PUBLIC_LABOLITA_DEMO_MODE=

# Somente para rotas server-side administrativas. Nunca exponha no browser.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: provedor de resultados. O app funciona em modo demonstração sem ela.
FOOTBALL_DATA_API_KEY=

# Sincronização de placares observados. Proteja o endpoint /api/cron/results.
RESULTS_FEED_URL=
# Opcional. Se vazio, usa a agenda pública da ESPN somente como contingência.
RESULTS_BACKUP_FEED_URL=
# Opcional. Atraso mínimo antes de auto-finalizar jogos de grupo finalizados pelo provedor (5 a 120 min; padrão 10).
RESULTS_AUTO_FINALIZE_DELAY_MINUTES=10
# Opcional. Se vazio, usa o bracket oficial da FIFA para preencher o mata-mata conhecido.
FIFA_BRACKET_FEED_URL=
# Opcional. Defina como true para pausar o preenchimento automatico do mata-mata.
FIFA_BRACKET_SYNC_DISABLED=
CRON_SECRET=
